from random import Random

from bab.combat.state import CombatState, Combatant
from bab.combat.effects import resolve_card
from bab.models import Card

PLAYED_CARD_EXHAUST_TAGS = {"exhaust", "vanish", "single_use", "temporary"}
UNPLAYABLE_CARD_TAGS = {"unplayable"}


def card_is_unplayable(card: Card) -> bool:
    return bool(set(card.tags) & UNPLAYABLE_CARD_TAGS)


def card_exhausts_when_played(card: Card) -> bool:
    return bool(set(card.tags) & PLAYED_CARD_EXHAUST_TAGS)


def build_deck(card_ids: list[str], card_database: dict[str, Card]) -> list[Card]:
    deck: list[Card] = []

    for card_id in card_ids:
        if card_id not in card_database:
            raise ValueError(f"Unknown card id in starting deck: {card_id}")

        deck.append(card_database[card_id])

    return deck


def shuffle_draw_pile(state: CombatState, rng: Random) -> None:
    rng.shuffle(state.draw_pile)
    state.log.append("Draw pile is shuffled.")


def shuffle_discard_into_draw_pile(state: CombatState, rng: Random) -> None:
    if not state.discard_pile:
        return

    state.draw_pile.extend(state.discard_pile)
    state.discard_pile.clear()

    rng.shuffle(state.draw_pile)
    state.log.append("Discard pile is shuffled into draw pile.")


def draw_cards(state: CombatState, amount: int, rng: Random) -> None:
    for _ in range(amount):
        if not state.draw_pile:
            shuffle_discard_into_draw_pile(state, rng)

        if not state.draw_pile:
            state.log.append("No cards left to draw.")
            return

        card = state.draw_pile.pop()
        state.hand.append(card)
        state.log.append(f"Player draws {card.name}.")


def discard_hand(state: CombatState) -> None:
    while state.hand:
        card = state.hand.pop()
        state.discard_pile.append(card)
        state.log.append(f"Player discards {card.name}.")


def play_card_from_hand(
    state: CombatState,
    hand_index: int,
    target: Combatant | None = None,
) -> None:
    if hand_index < 0 or hand_index >= len(state.hand):
        raise IndexError(f"Invalid hand index: {hand_index}")

    card = state.hand[hand_index]

    if card.cost > state.energy:
        state.log.append(
            f"Not enough Energy to play {card.name}. "
            f"Needed {card.cost}, had {state.energy}."
        )
        return

    state.energy -= card.cost
    state.hand.pop(hand_index)

    resolve_card(card, state, target)

    state.discard_pile.append(card)
    state.log.append(f"{card.name} goes to discard pile.")